{
    "name": "capacitor-metronome-background",
    "version": "1.1.0",
    "description": "Local Capacitor plugin for native background metronome playback",
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "files": [
        "android/src/main/",
        "android/build.gradle",
        "dist/",
        "ios/Sources",
        "src/",
        "CapacitorMetronomeBackground.podspec"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json"
    },
    "license": "MIT",
    "peerDependencies": {
        "@capacitor/core": ">=8.0.0"
    },
    "capacitor": {
        "android": {
            "src": "android"
        },
        "ios": {
            "src": "ios"
        }
    }
}
